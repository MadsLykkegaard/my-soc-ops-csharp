@using SocOps.Models

<button
    @onclick="OnClick"
    disabled="@Square.IsFreeSpace"
    class="@GetCssClasses()"
    aria-pressed="@Square.IsMarked"
    aria-label="@(Square.IsFreeSpace ? "Free space" : Square.Text)">
    <span class="fish-icon">@GetFishEmoji()</span>
    <span class="square-label">@Square.Text</span>
    @if (Square.IsMarked && !Square.IsFreeSpace)
    {
        <span class="absolute top-0.5 right-0.5 text-[#ffb347] text-xs">✓</span>
    }
</button>

@code {
    [Parameter]
    public BingoSquareData Square { get; set; } = null!;

    [Parameter]
    public bool IsWinning { get; set; }

    [Parameter]
    public EventCallback OnClick { get; set; }

    private string GetCssClasses()
    {
        var baseClasses = "square-card transition-all duration-150 select-none";

        var stateClasses = Square.IsMarked
            ? IsWinning
                ? "marked win"
                : "marked"
            : string.Empty;

        var freeSpaceClasses = Square.IsFreeSpace ? "anchor-label" : string.Empty;

        return $"{baseClasses} {stateClasses} {freeSpaceClasses}".Trim();
    }

    private string GetFishEmoji()
    {
        if (Square.IsFreeSpace)
        {
            return "⚓";
        }

        var shape = Square.Id % 7;
        switch (shape)
        {
            case 0: return "🐠";
            case 1: return "🐟";
            case 2: return "🐡";
            case 3: return "🐬";
            case 4: return "🦀";
            case 5: return "🦑";
            case 6: return "🐙";
            default: return "🐟";
        }
    }
}
