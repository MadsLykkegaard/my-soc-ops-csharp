@using SocOps.Models

<div class="flex flex-col min-h-full ocean-page">
    <header class="flex items-center justify-between px-4 py-4" style="border-bottom: 1px solid rgba(255,255,255,0.18);">
        <button
            @onclick="OnReset"
            class="fancy-button"
            style="background: rgba(255,255,255,0.12); color: #f4f2ec; box-shadow: none; border: 1px solid rgba(255,255,255,0.18);">
            ← Drop Anchor
        </button>

        <div class="flex items-center gap-3 text-left">
            <div class="relative flex h-14 w-14 items-center justify-center rounded-full" style="background: rgba(255,255,255,0.12); border: 1px solid rgba(255,255,255,0.16);">
                <span>🎣</span>
            </div>
            <div>
                <div class="text-sm" style="color: #ffd688; letter-spacing: 0.22em; text-transform: uppercase;">Fishing Log</div>
                <h1 class="text-3xl font-bold">Sea Bingo</h1>
            </div>
        </div>

        <div class="w-16"></div>
    </header>

    <p class="text-center" style="color: #d8e9f7; font-size: 0.95rem; padding: 0.65rem 1rem;">
        Tap a square when you find someone who matches the catch and reel in your line.
    </p>

    @if (HasBingo)
    {
        <div class="catch-banner">
            🪝 You reeled in a winning line! The net is full.
        </div>
    }

    <div class="flex-1 flex items-center justify-center p-4">
        <div class="board-shell">
            <BingoBoard
                Board="@Board"
                WinningSquareIds="@WinningSquareIds"
                OnSquareClick="@OnSquareClick" />
        </div>
    </div>
</div>

@code {
    [Parameter]
    public List<BingoSquareData> Board { get; set; } = new();

    [Parameter]
    public HashSet<int> WinningSquareIds { get; set; } = new();

    [Parameter]
    public bool HasBingo { get; set; }

    [Parameter]
    public EventCallback<int> OnSquareClick { get; set; }

    [Parameter]
    public EventCallback OnReset { get; set; }
}
